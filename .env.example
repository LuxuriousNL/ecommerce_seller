# Copy to .env and fill in. NEVER commit .env.

# --- Printify ---
# Account > Settings > Connections > Generate a Personal Access Token
PRINTIFY_API_TOKEN=

# Your Printify shop id. Run `etsyshop printify shops` to discover it once the token is set.
PRINTIFY_SHOP_ID=

# --- Etsy (Open API v3) ---
# https://www.etsy.com/developers/your-apps -> create an app -> "Keystring" is the API key.
ETSY_API_KEY=
# Shared secret of the app (only needed for some flows; OAuth v3 uses PKCE so this is optional).
ETSY_API_SECRET=
# Numeric shop id. Run `etsyshop etsy whoami` after authorizing to discover it.
ETSY_SHOP_ID=
# Must EXACTLY match a redirect URI registered on your Etsy app.
ETSY_REDIRECT_URI=http://localhost:8080/callback

# --- Anthropic (Phase 2: AI listing optimization) ---
ANTHROPIC_API_KEY=
# Latest Opus model id for the optimization engine.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Image generation (the design seam) ---
# auto picks Recraft for vector products (stickers/tees), OpenAI otherwise;
# degrades to "manual" (writes the brief to a file) when no key is set.
IMAGE_PROVIDER=auto
OPENAI_API_KEY=
RECRAFT_API_KEY=
